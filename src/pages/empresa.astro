---
import Layout from '../layouts/Layout.astro';

const stats = [
  { value: '20+', label: 'Anos de Experiência' },
  { value: '15k+', label: 'Clientes Ativos' },
  { value: '17', label: 'Cidades Atendidas' },
  { value: '99.9%', label: 'Uptime Garantido' },
];

const values = [
  {
    title: 'Qualidade',
    description: 'Internet de alta velocidade com fibra óptica de última geração.',
    icon: '<svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>'
  },
  {
    title: 'Compromisso',
    description: 'Dedicados a fornecer o melhor serviço para nossos clientes.',
    icon: '<svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
  },
  {
    title: 'Inovação',
    description: 'Sempre investindo em tecnologia para offerer a melhor experiência.',
    icon: '<svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>'
  },
  {
    title: 'Proximidade',
    description: 'Estamos perto de você com atendimento personalizado.',
    icon: '<svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>'
  },
];
---

<Layout title="Empresa - RzNet Fibra">
  <section class="relative pt-32 pb-24 overflow-hidden">
    <div class="absolute inset-0 hero-gradient"></div>
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Conheça a <span class="gradient-text">RzNet Fibra</span>
        </h1>
        <p class="text-lg text-gray-400 max-w-3xl mx-auto leading-relaxed">
          A <strong class="text-white">RzNet Fibra</strong> é uma empresa que leva a você internet de alta velocidade, 
          com planos acessíveis, e suporte técnico de extrema qualidade.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20">
        {stats.map((stat) => (
          <div class="text-center">
            <p class="text-4xl sm:text-5xl font-bold gradient-text mb-2">{stat.value}</p>
            <p class="text-sm text-gray-500">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6">
          <h2 class="text-3xl font-bold text-white">
            Mais de <span class="text-brand">20 anos</span> conectando pessoas
          </h2>
          <p class="text-gray-400 leading-relaxed">
            Estabelecida no mercado há mais de 20 anos, a <strong class="text-white">RzNet Fibra</strong> está 
            presente em 17 localidades Mineiras. A qualidade dos serviços oferecidos é o foco principal da empresa.
          </p>
          <p class="text-gray-400 leading-relaxed">
            Contando com uma cartela de mais de 15 mil clientes em Curvelo e região, a nossa empresa está 
            em constante evolução, a fim de satisfazer as necessidades dos seus clientes.
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <div class="flex items-center gap-2 text-sm text-gray-400">
              <svg class="h-5 w-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Fibra Óptica Premium
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-400">
              <svg class="h-5 w-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Suporte Técnico 24h
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-400">
              <svg class="h-5 w-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Planos Sem Limite
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 bg-brand/10 rounded-3xl blur-3xl"></div>
          <div class="relative glass rounded-3xl p-8 sm:p-12">
            <div class="grid grid-cols-2 gap-6">
              {values.map((value) => (
                <div class="text-center p-6 rounded-2xl bg-white/5 border border-white/5">
                  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand/10 border border-brand/20 mx-auto mb-4">
                    <Fragment set:html={value.icon} />
                  </div>
                  <h3 class="font-semibold text-white mb-2">{value.title}</h3>
                  <p class="text-xs text-gray-500">{value.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="glass rounded-3xl p-8 sm:p-12 lg:p-16 text-center">
        <h2 class="text-3xl font-bold text-white mb-6">
          Faça parte da nossa história
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto mb-8">
          Junte-se a mais de 15 mil clientes satisfeitos. Assine agora e descubra 
          o que é internet de verdade.
        </p>
        <a
          href="https://api.whatsapp.com/send?phone=553837296550"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-brand px-8 py-4 text-base font-bold text-white transition-all hover:bg-brand-dark hover:shadow-xl hover:shadow-brand/30"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Assine Agora
        </a>
      </div>
    </div>
  </section>
</Layout>
