---
import Layout from '../layouts/Layout.astro';

const cities = [
  'Curvelo',
  'Corinto',
  'Pompéu',
  'Paraopeba',
  'Baldim',
  'Paraúna',
  'Goiatuba',
  'Cachoeira Danta',
  'Bonfinópolis',
  'Abadiânia',
  'Acreúna',
  'Águas Lindas de Goiás',
  'Alexânia',
  'Alto Paraíso de Goiás',
  'Áporá',
  'Araporã',
  'Barro Alto',
  'Bela Vista de Goiás',
];
---

<Layout title="Cobertura - RzNet Fibra">
  <section class="relative pt-32 pb-24 overflow-hidden">
    <div class="absolute inset-0 hero-gradient"></div>
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Nossa <span class="gradient-text">Cobertura</span>
        </h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">
          A RzNet Fibra está presente em 17 localidades mineiras, levando 
          internet de qualidade para toda a região.
        </p>
      </div>
    </div>
  </section>

  <section class="relative py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block text-sm font-bold text-brand tracking-[0.2em] uppercase mb-4">Nossa Rede</span>
        <h2 class="text-4xl sm:text-5xl font-black text-white mb-6 tracking-tight">
          17 cidades <span class="text-brand">conectadas</span>
        </h2>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">
          A RzNet Fibra está presente em toda a região, levando internet de qualidade para você.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <div class="lg:col-span-2">
          <div class="rounded-3xl p-8 bg-gradient-to-br from-white/[0.04] to-transparent border border-white/[0.06]">
            <div class="flex items-center gap-3 mb-6">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand/15 border border-brand/20">
                <svg class="h-5 w-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">Áreas Atendidas</h3>
            </div>
            <div class="space-y-2">
              {cities.map((city) => (
                <div class="group flex items-center gap-3 px-4 py-3 rounded-xl bg-white/[0.03] border border-white/[0.05] hover:border-brand/30 hover:bg-brand/[0.05] transition-all duration-300">
                  <svg class="h-3.5 w-3.5 text-brand shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="4"/>
                  </svg>
                  <span class="text-sm font-medium text-gray-300 group-hover:text-white transition-colors">{city}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-3">
          <div class="rounded-3xl p-8 bg-gradient-to-br from-white/[0.04] to-transparent border border-white/[0.06]">
            <div class="flex items-center gap-3 mb-6">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand/15 border border-brand/20">
                <svg class="h-5 w-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">Mapa de Cobertura</h3>
            </div>
            <div class="rounded-2xl overflow-hidden border border-white/[0.05] h-[480px]">
              <iframe
                src="https://www.google.com/maps/d/embed?mid=1y7pzr-QpU272zWMCcUunhY0uFkzOEoU6&ll=-26.217055088737304,-49.97406004999999&z=9"
                width="100%"
                height="100%"
                style="border:0; filter: invert(90%) hue-rotate(180deg) brightness(0.9) contrast(1.1);"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Mapa de Cobertura RzNet"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="glass rounded-3xl p-8 sm:p-12 lg:p-16 text-center">
        <h2 class="text-3xl font-bold text-white mb-6">
          Sua cidade não está na lista?
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto mb-8">
          Nossa rede de fibra óptica está em constante expansão. 
          Entre em contato e saiba quando estaremos na sua região.
        </p>
        <a
          href="https://api.whatsapp.com/send?phone=553837296550"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-brand px-8 py-4 text-base font-bold text-white transition-all hover:bg-brand-dark hover:shadow-xl hover:shadow-brand/30"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Entre em Contato
        </a>
      </div>
    </div>
  </section>
</Layout>
