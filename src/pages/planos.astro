---
import Layout from '../layouts/Layout.astro';
import PlanCard from '../components/PlanCard.astro';

const plans = [
  {
    name: 'Pessoal',
    speed: '100',
    price: '79,90',
    features: [
      '100 Mbps de velocidade',
      'Internet ilimitada',
      'Wi-Fi incluso',
      'Suporte técnico',
      'Instalação grátis',
      '1 ponto de acesso',
      'Sem fidelidade',
    ],
  },
  {
    name: 'Família',
    speed: '200',
    price: '99,90',
    features: [
      '200 Mbps de velocidade',
      'Internet ilimitada',
      'Wi-Fi 6 incluso',
      'Suporte prioritário',
      'Instalação grátis',
      '2 pontos de acesso',
      'Sem fidelidade',
    ],
    popular: true,
  },
  {
    name: 'Premium',
    speed: '500',
    price: '139,90',
    features: [
      '500 Mbps de velocidade',
      'Internet ilimitada',
      'Wi-Fi 6 Pro incluso',
      'Suporte VIP 24h',
      'Instalação grátis',
      '3 pontos de acesso',
      'IP fixo disponível',
    ],
  },
];

const plansEmpresa = [
  {
    name: 'Business',
    speed: '300',
    price: '199,90',
    features: [
      '300 Mbps simétrico',
      'Internet ilimitada',
      'Wi-Fi 6 Business',
      'Suporte dedicado',
      'Instalação grátis',
      'IP fixo incluso',
    ],
  },
  {
    name: 'Enterprise',
    speed: '1000',
    price: '399,90',
    features: [
      '1 Gbps simétrico',
      'Internet ilimitada',
      'Wi-Fi 6E Enterprise',
      'Suporte 24/7 dedicado',
      'SLA garantido',
      'IP fixo incluso',
      'Backup de link',
    ],
    popular: true,
  },
];
---

<Layout title="Planos - RzNet Fibra">
  <section class="relative min-h-[30vh] flex items-center justify-center pt-40 pb-12 overflow-hidden">
    <div class="absolute inset-0 hero-gradient"></div>
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 mt-[15px]">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Nossos <span class="gradient-text">Planos</span>
        </h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">
          Escolha o plano ideal para você. Internet de alta velocidade com 
          fibra óptica premium e sem limite de dados.
        </p>
      </div>
    </div>
  </section>

  <section class="relative pb-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold text-white mb-4">Para Você</h2>
        <p class="text-gray-500">Planos residenciais com a melhor qualidade</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-24 items-stretch">
        {plans.map((plan) => (
          <PlanCard
            name={plan.name}
            speed={plan.speed}
            price={plan.price}
            features={plan.features}
            popular={plan.popular}
          />
        ))}
      </div>

      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold text-white mb-4">Para Empresas</h2>
        <p class="text-gray-500">Planos corporativos com suporte dedicado</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto items-stretch">
        {plansEmpresa.map((plan) => (
          <PlanCard
            name={plan.name}
            speed={plan.speed}
            price={plan.price}
            features={plan.features}
            popular={plan.popular}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="relative py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="glass rounded-3xl p-8 sm:p-12 lg:p-16 text-center">
        <h2 class="text-3xl font-bold text-white mb-6">
          Precisa de um plano personalizado?
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto mb-8">
          Entre em contato conosco e montaremos um plano sob medida para sua empresa.
        </p>
        <a
          href="https://api.whatsapp.com/send?phone=553837296550"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-brand px-8 py-4 text-base font-bold text-white transition-all hover:bg-brand-dark hover:shadow-xl hover:shadow-brand/30"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Falar com Consultor
        </a>
      </div>
    </div>
  </section>
</Layout>
