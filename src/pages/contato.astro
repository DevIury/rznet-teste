---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contato - RzNet Fibra">
  <section class="relative min-h-[30vh] flex items-center justify-center pt-40 pb-12 overflow-hidden">
    <div class="absolute inset-0 hero-gradient"></div>
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 mt-[15px]">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Entre em <span class="gradient-text">Contato</span>
        </h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">
          Estamos prontos para atender você. Preencha o formulário ou entre em contato pelos nossos canais.
        </p>
      </div>
    </div>
  </section>

  <section class="relative pb-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl p-8 sm:p-12 bg-white/[0.03] border border-white/[0.06]">
        <div class="text-center mb-10">
          <h2 class="text-2xl sm:text-3xl font-bold text-brand mb-4">Fale Conosco</h2>
          <p class="text-gray-500 text-sm max-w-xl mx-auto">
            Nos envie uma mensagem informando o plano que mais se adequa a você juntamente com seu endereço.
          </p>
        </div>

        <form id="contact-form" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="space-y-4">
            <input
              type="text"
              name="nome"
              placeholder="Nome"
              required
              class="w-full px-5 py-4 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-gray-500 text-sm focus:outline-none focus:border-brand/50 focus:bg-brand/[0.03] transition-all duration-300"
            />
            <input
              type="email"
              name="email"
              placeholder="Email"
              required
              class="w-full px-5 py-4 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-gray-500 text-sm focus:outline-none focus:border-brand/50 focus:bg-brand/[0.03] transition-all duration-300"
            />
            <input
              type="tel"
              name="telefone"
              placeholder="Telefone"
              required
              class="w-full px-5 py-4 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-gray-500 text-sm focus:outline-none focus:border-brand/50 focus:bg-brand/[0.03] transition-all duration-300"
            />
            <input
              type="text"
              name="cidade"
              placeholder="Cidade/UF"
              required
              class="w-full px-5 py-4 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-gray-500 text-sm focus:outline-none focus:border-brand/50 focus:bg-brand/[0.03] transition-all duration-300"
            />
            <select
              name="tipo"
              required
              class="w-full px-5 py-4 rounded-xl bg-white/[0.04] border border-white/[0.08] text-gray-500 text-sm focus:outline-none focus:border-brand/50 focus:bg-brand/[0.03] transition-all duration-300 appearance-none cursor-pointer"
            >
              <option value="" disabled selected>Selecione o assunto</option>
              <option value="comercial">Comercial</option>
              <option value="suporte">Suporte</option>
              <option value="financeiro">Financeiro</option>
            </select>
          </div>

          <div class="flex flex-col gap-4">
            <textarea
              name="mensagem"
              placeholder="Mensagem"
              rows="8"
              required
              class="w-full h-full px-5 py-4 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-gray-500 text-sm focus:outline-none focus:border-brand/50 focus:bg-brand/[0.03] transition-all duration-300 resize-none"
            ></textarea>
            <button
              type="submit"
              class="w-full rounded-xl bg-brand px-8 py-4 text-base font-bold text-white transition-all hover:bg-brand-dark hover:shadow-xl hover:shadow-brand/30 hover:scale-[1.01]"
            >
              Enviar
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section class="relative py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="group text-center p-8 rounded-2xl bg-white/[0.03] border border-white/[0.06] hover:border-brand/30 hover:bg-brand/[0.04] transition-all duration-500">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand/10 border border-brand/15 mx-auto mb-4 transition-all duration-500 group-hover:scale-110">
            <svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <h3 class="font-bold text-white mb-2">Telefone</h3>
          <a href="https://api.whatsapp.com/send?phone=553837296550" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 hover:text-brand transition-colors">(38) 3729-6550</a>
        </div>

        <div class="group text-center p-8 rounded-2xl bg-white/[0.03] border border-white/[0.06] hover:border-brand/30 hover:bg-brand/[0.04] transition-all duration-500">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand/10 border border-brand/15 mx-auto mb-4 transition-all duration-500 group-hover:scale-110">
            <svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-bold text-white mb-2">Email</h3>
          <p class="text-sm text-gray-500">contato@rznet.com.br</p>
        </div>

        <div class="group text-center p-8 rounded-2xl bg-white/[0.03] border border-white/[0.06] hover:border-brand/30 hover:bg-brand/[0.04] transition-all duration-500">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand/10 border border-brand/15 mx-auto mb-4 transition-all duration-500 group-hover:scale-110">
            <svg class="h-6 w-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-white mb-2">Endereço</h3>
          <a href="https://maps.google.com/?q=Rua+Sete+de+Setembro+205+Centro+Curvelo+MG+35790-345" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 hover:text-brand transition-colors">Rua Sete de Setembro, 205<br/>Curvelo - MG</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form as HTMLFormElement);
    const nome = formData.get('nome');
    const email = formData.get('email');
    const telefone = formData.get('telefone');
    const cidade = formData.get('cidade');
    const tipo = formData.get('tipo');
    const mensagem = formData.get('mensagem');
    
    const text = `*Novo Contato - RzNet*%0A%0ANome: ${nome}%0AEmail: ${email}%0ATelefone: ${telefone}%0ACidade: ${cidade}%0AAssunto: ${tipo}%0AMensagem: ${mensagem}`;
    window.open(`https://api.whatsapp.com/send?phone=553837296550&text=${text}`, '_blank');
  });
</script>
