---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  {
    title: 'Velocidade Suprema',
    description: 'Fibra óptica de última geração com velocidades de até 1 Gbps para suas conexões.',
    icon: '<svg class="h-7 w-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>'
  },
  {
    title: 'Conexão Estável',
    description: 'Internet ilimitada sem franquia, com estabilidade garantida 24 horas por dia, 7 dias por semana.',
    icon: '<svg class="h-7 w-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>'
  },
  {
    title: 'Suporte Dedicado',
    description: 'Equipe técnica disponível todos os dias para resolver qualquer problema com sua conexão.',
    icon: '<svg class="h-7 w-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>'
  },
  {
    title: 'Planos Acessíveis',
    description: 'Internet de qualidade com preços que cabem no seu bolso. Planos para todos os perfis.',
    icon: '<svg class="h-7 w-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
  },
  {
    title: 'Cobertura Regional',
    description: 'Presente em 17 localidades mineiras, levando internet de qualidade para toda a região.',
    icon: '<svg class="h-7 w-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
  },
  {
    title: 'Instalação Grátis',
    description: 'Instalação profissional sem custo adicional. Nossa equipe cuida de tudo para você.',
    icon: '<svg class="h-7 w-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>'
  }
];
---

  <Layout title="RzNet Fibra - Internet de Alta Velocidade em Curvelo">
  <Hero />

  <section class="relative py-12 overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a
        href="https://www.rznet.com.br/central_assinante_web/login"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-between gap-6 rounded-2xl px-8 py-6 bg-gradient-to-r from-white/[0.04] to-transparent border border-white/[0.06] hover:border-brand/30 hover:bg-brand/[0.04] transition-all duration-500"
      >
        <div class="flex items-center gap-5">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-brand/15 border border-brand/20 shrink-0 transition-all duration-500 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-brand/20">
            <svg class="h-7 w-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white group-hover:text-brand transition-colors">Central do Assinante</h3>
            <p class="text-sm text-gray-500">Acesse sua conta, faturas, pontos de acesso e muito mais</p>
          </div>
        </div>
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/[0.05] border border-white/[0.08] group-hover:bg-brand/10 group-hover:border-brand/20 transition-all duration-300 shrink-0">
          <svg class="h-5 w-5 text-gray-500 group-hover:text-brand transition-all duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </div>
      </a>
    </div>
  </section>

  <section class="relative py-28 overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 0%, rgba(255,0,0,0.05) 0%, transparent 60%);"></div>
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-20">
        <span class="inline-block text-sm font-bold text-brand tracking-[0.2em] uppercase mb-4">Nossos Serviços</span>
        <h2 class="text-4xl sm:text-5xl font-black text-white mb-6 tracking-tight">
          Tenha RzNet e se <span class="text-brand">surpreenda!</span>
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto text-lg leading-relaxed">
          Oferecemos internet de alta velocidade com fibra óptica premium. 
          Conecte-se com a melhor experiência de navegação da região.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            icon={service.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="relative py-24 overflow-hidden bg-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl p-8 sm:p-12 lg:p-16 text-center" style="background: linear-gradient(135deg, rgba(255,0,0,0.2) 0%, rgba(150,0,0,0.1) 100%); border: 1px solid rgba(255,0,0,0.2);">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
          Pronto para ter a melhor internet da região?
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto mb-8">
          Assine agora mesmo e descubra o que é internet de verdade. 
          Velocidade, estabilidade e suporte que você merece.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://api.whatsapp.com/send?phone=553837296550"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-brand px-8 py-4 text-base font-bold text-white transition-all hover:bg-brand-dark hover:shadow-xl hover:shadow-brand/30"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Fale com um Consultor
          </a>
          <a
            href="/planos"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-8 py-4 text-base font-semibold text-white transition-all hover:bg-white/10"
          >
            Ver Todos os Planos
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
