---
const currentYear = new Date().getFullYear();

const footerLinks = {
  menu: [
    { label: 'Início', href: '/' },
    { label: 'Empresa', href: '/empresa' },
    { label: 'Cobertura', href: '/cobertura' },
    { label: 'Planos', href: '/planos' },
    { label: 'Dúvidas Frequentes', href: '/duvidas' },
  ],
  planos: [
    { label: 'Para Você', href: '/planos' },
    { label: 'Para Empresas', href: '/planos' },
  ],
};

const contactInfo = {
  phone: '(38) 3729-6550',
  whatsapp: '(38) 3729-6550',
  backupPhones: [
    '(38) 9.9854-6552',
    '(38) 9.9875-6553',
    '(38) 9.9882-6553',
    '(38) 9.9737-6551',
    '(38) 9.9745-8420',
    '(38) 9.9846-1532',
  ],
  address: 'Rua Sete de Setembro, 205 - Centro, Curvelo - MG, 35790-345',
};
---

<footer class="relative border-t border-white/5 bg-dark">
  <div class="absolute inset-0 hero-gradient opacity-30 pointer-events-none"></div>
  
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <div>
        <a href="/" class="flex items-center gap-3 mb-6">
          <img src="/logo.png" alt="RzNet Fibra" class="h-[176px] w-auto drop-shadow-lg" />
        </a>
        <p class="text-sm text-gray-500 leading-relaxed">
          Internet de alta velocidade com fibra óptica premium. Presente em 17 localidades mineiras com mais de 20 anos de experiência.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-6">Menu</h3>
        <ul class="space-y-3">
          {footerLinks.menu.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-brand transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-6">Planos</h3>
        <ul class="space-y-3">
          {footerLinks.planos.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-brand transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-6">Contato</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <svg class="h-5 w-5 text-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <div>
              <p class="text-sm text-white font-medium">{contactInfo.phone}</p>
              <p class="text-xs text-gray-600">WhatsApp e Ligações</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3">
            <svg class="h-5 w-5 text-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-sm text-gray-500">{contactInfo.address}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/5">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-gray-600">
          © {currentYear} RzNet Fibra - Todos os direitos reservados.
        </p>
        <p class="text-xs text-gray-700">
          Fibra óptica premium em Curvelo e região
        </p>
      </div>
    </div>
  </div>
</footer>
