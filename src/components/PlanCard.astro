---
interface Props {
  name: string;
  speed: string;
  price: string;
  features: string[];
  popular?: boolean;
}

const { name, speed, price, features, popular = false } = Astro.props;
---

<div class:list={[
  'relative rounded-2xl p-8 card-hover',
  popular 
    ? 'bg-gradient-to-b from-brand/10 to-transparent border-2 border-brand/30' 
    : 'glass border border-white/5'
]}>
  {popular && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
      <span class="rounded-full bg-brand px-4 py-1.5 text-xs font-bold text-white uppercase tracking-wider">
        Mais Popular
      </span>
    </div>
  )}
  
  <div class="text-center mb-8">
    <h3 class="text-lg font-semibold text-gray-400 mb-2">{name}</h3>
    <div class="flex items-baseline justify-center gap-1 mb-4">
      <span class="text-5xl font-bold text-white">{speed}</span>
      <span class="text-lg text-gray-500">Mbps</span>
    </div>
    <div class="flex items-baseline justify-center gap-1">
      <span class="text-sm text-gray-500">R$</span>
      <span class="text-3xl font-bold text-brand">{price}</span>
      <span class="text-sm text-gray-500">/mês</span>
    </div>
  </div>

  <div class="h-px bg-white/5 mb-8"></div>

  <ul class="space-y-4 mb-8">
    {features.map((feature) => (
      <li class="flex items-center gap-3">
        <svg class="h-5 w-5 text-brand shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span class="text-sm text-gray-400">{feature}</span>
      </li>
    ))}
  </ul>

  <a
    href="https://api.whatsapp.com/send?phone=553837296550"
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'flex items-center justify-center w-full rounded-xl py-4 text-sm font-bold transition-all',
      popular
        ? 'bg-brand text-white hover:bg-brand-dark hover:shadow-lg hover:shadow-brand/30'
        : 'bg-white/5 text-white border border-white/10 hover:bg-white/10 hover:border-white/20'
    ]}
  >
    Assine Agora
  </a>
</div>
