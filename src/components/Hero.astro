---
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-24" style="background: linear-gradient(160deg, #ff0000 0%, #cc0000 35%, #8b0000 70%, #4a0000 100%);">
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 20% 80%, rgba(255,200,0,0.08) 0%, transparent 50%);"></div>
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 80% 10%, rgba(255,255,255,0.06) 0%, transparent 40%);"></div>
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 50%, rgba(0,0,0,0.2) 0%, transparent 60%);"></div>
  
  <div class="absolute top-20 left-10 w-3 h-3 bg-white/20 rounded-full animate-float" style="animation-delay: 0s;"></div>
  <div class="absolute top-40 right-20 w-2 h-2 bg-accent/40 rounded-full animate-float" style="animation-delay: 0.5s;"></div>
  <div class="absolute bottom-32 left-1/4 w-4 h-4 bg-white/10 rounded-full animate-float" style="animation-delay: 1s;"></div>
  <div class="absolute top-1/3 right-1/3 w-2 h-2 bg-white/15 rounded-full animate-float" style="animation-delay: 1.5s;"></div>
  <div class="absolute bottom-20 right-10 w-3 h-3 bg-accent/20 rounded-full animate-float" style="animation-delay: 2s;"></div>

  <div class="absolute top-1/4 left-1/6 w-80 h-80 bg-white/5 rounded-full blur-3xl animate-float"></div>
  <div class="absolute bottom-1/4 right-1/6 w-96 h-96 bg-black/10 rounded-full blur-3xl animate-float" style="animation-delay: 1.5s;"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 backdrop-blur-sm px-5 py-2.5">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-accent"></span>
          </span>
          <span class="text-sm font-medium text-white tracking-wide">Fibra Óptica Premium</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black leading-[1.1] text-white drop-shadow-lg">
          A fibra óptica
          <span class="relative inline-block">
            <span class="relative z-10 text-accent"> Premium</span>
          </span>
          <br />em Curvelo e
          <br />Região!
        </h1>

        <p class="text-lg sm:text-xl text-white/80 max-w-xl leading-relaxed font-light">
          Seja <span class="text-white font-semibold">líder</span> em qualidade de atendimento e tenha{" "}
          <span class="text-white font-semibold">velocidade suprema</span> para suas conexões!
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="https://api.whatsapp.com/send?phone=553837296550"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-3 rounded-2xl bg-white px-8 py-5 text-base font-bold text-brand transition-all hover:bg-accent hover:text-dark hover:shadow-2xl hover:shadow-black/30 hover:-translate-y-1"
          >
            <svg class="h-5 w-5 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Assine Agora
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="/planos"
            class="inline-flex items-center justify-center gap-3 rounded-2xl border-2 border-white/25 bg-white/5 backdrop-blur-sm px-8 py-5 text-base font-semibold text-white transition-all hover:bg-white/15 hover:border-white/40 hover:-translate-y-1"
          >
            Ver Planos
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <div class="flex items-center gap-8 pt-4">
          <div class="text-center">
            <p class="text-3xl sm:text-4xl font-black text-white">15k+</p>
            <p class="text-sm text-white/60 font-medium">Clientes</p>
          </div>
          <div class="h-12 w-px bg-white/20"></div>
          <div class="text-center">
            <p class="text-3xl sm:text-4xl font-black text-white">17</p>
            <p class="text-sm text-white/60 font-medium">Cidades</p>
          </div>
          <div class="h-12 w-px bg-white/20"></div>
          <div class="text-center">
            <p class="text-3xl sm:text-4xl font-black text-white">20+</p>
            <p class="text-sm text-white/60 font-medium">Anos</p>
          </div>
        </div>
      </div>

      <div class="relative hidden lg:flex items-center justify-center">
        <div class="relative w-full max-w-md">
          <div class="absolute inset-0 bg-black/20 rounded-3xl blur-3xl"></div>
          <div class="relative rounded-3xl p-8 space-y-6 bg-white/10 backdrop-blur-md border border-white/15 shadow-2xl">
            <div class="flex items-center gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/15 border border-white/20">
                <svg class="h-7 w-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-white">Velocidade Suprema</h3>
                <p class="text-sm text-white/60">Fibra óptica de alta performance</p>
              </div>
            </div>
            <div class="h-px bg-white/10"></div>
            <div class="flex items-center gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/15 border border-white/20">
                <svg class="h-7 w-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-white">Suporte 24h</h3>
                <p class="text-sm text-white/60">Atendimento dedicado para você</p>
              </div>
            </div>
            <div class="h-px bg-white/10"></div>
            <div class="flex items-center gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/15 border border-white/20">
                <svg class="h-7 w-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-white">Planos Acessíveis</h3>
                <p class="text-sm text-white/60">Qualidade com preço justo</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
