---
const navItems = [
  { label: 'Início', href: '/' },
  { label: 'Empresa', href: '/empresa' },
  { label: 'Planos', href: '/planos' },
  { label: 'Cobertura', href: '/cobertura' },
  { label: 'Dúvidas', href: '/duvidas' },
];
---

<div class="fixed top-0 left-0 right-0 z-[60] bg-brand">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-end h-9">
      <a
        href="https://www.rznet.com.br/central_assinante_web/login"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-xs font-semibold text-white/90 hover:text-white transition-colors"
      >
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        Minha conta
      </a>
    </div>
  </div>
</div>

<header id="header" class="fixed left-0 right-0 z-50 transition-all duration-300" style="top: 36px;">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-[145px] items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <img src="/logo.png" alt="RzNet Fibra" class="h-[115px] w-auto drop-shadow-lg" />
      </a>

      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="relative px-5 py-2.5 text-[15px] font-semibold text-white tracking-wide rounded-xl transition-all duration-300 hover:bg-[#8b0000] hover:shadow-lg hover:shadow-black/20 hover:scale-105"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-4">
        <a
          href="https://api.whatsapp.com/send?phone=553837296550"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-2.5 rounded-xl bg-white px-6 py-2.5 text-[14px] font-bold text-brand transition-all duration-300 hover:bg-accent hover:text-dark hover:shadow-xl hover:shadow-black/20 hover:scale-105"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Assine Agora
        </a>

        <button
          id="mobile-menu-btn"
          class="lg:hidden flex items-center justify-center w-11 h-11 rounded-xl bg-white/10 text-white hover:bg-[#8b0000] transition-all duration-300 hover:scale-110"
          aria-label="Menu"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/5" style="background: linear-gradient(180deg, rgba(10,0,0,0.95) 0%, rgba(20,0,0,0.98) 100%); backdrop-filter: blur(20px);">
    <div class="mx-auto max-w-7xl px-5 py-6 space-y-1">
      {navItems.map((item, i) => (
        <a
          href={item.href}
          class="flex items-center gap-3 px-5 py-4 text-[16px] font-semibold text-white/90 tracking-wide rounded-2xl transition-all duration-300 hover:bg-[#8b0000]/80 hover:text-white hover:shadow-lg hover:shadow-[#8b0000]/10 hover:translate-x-1 group"
          style={`animation: slideIn 0.3s ease-out ${i * 0.05}s both;`}
        >
          <span class="w-1.5 h-1.5 rounded-full bg-brand/40 group-hover:bg-accent transition-colors duration-300"></span>
          {item.label}
        </a>
      ))}
      <div class="pt-4">
        <a
          href="https://api.whatsapp.com/send?phone=553837296550"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-3 w-full rounded-2xl bg-gradient-to-r from-brand to-brand-dark px-6 py-4 text-[15px] font-bold text-white transition-all duration-300 hover:shadow-xl hover:shadow-brand/30 hover:scale-[1.02]"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Assine Agora
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
  <style>
    @keyframes slideIn {
      from { opacity: 0; transform: translateX(-12px); }
      to { opacity: 1; transform: translateX(0); }
    }
  </style>
</header>

<script>
  const header = document.getElementById('header');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('shadow-lg');
      header!.style.background = 'rgba(10, 0, 0, 0.85)';
      header!.style.backdropFilter = 'blur(16px)';
      header!.style.borderBottom = '1px solid rgba(255, 0, 0, 0.15)';
    } else {
      header?.classList.remove('shadow-lg');
      header!.style.background = 'transparent';
      header!.style.backdropFilter = 'none';
      header!.style.borderBottom = 'none';
    }
  });

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
